# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# 0G Network - Galileo Testnet
ZERO_G_RPC=https://evmrpc-testnet.0g.ai
ZERO_G_STORAGE_INDEXER=https://indexer-storage-testnet-standard.0g.ai
FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# Backend wallet (used for storage submissions)
# Generate a new wallet: npx ts-node -e "const { ethers } = require('ethers'); const w = ethers.Wallet.createRandom(); console.log(w.privateKey)"
BACKEND_PRIVATE_KEY=your_private_key_here

# 0G Compute Network (OpenAI-compatible)
ZERO_G_COMPUTE_BASE_URL=https://api.0g.ai/v1
ZERO_G_COMPUTE_API_KEY=your_0g_compute_api_key
ZERO_G_COMPUTE_MODEL=glm-4
